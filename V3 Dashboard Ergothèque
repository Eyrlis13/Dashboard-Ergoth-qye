<!-- ══ VUE D'ENSEMBLE ══ -->
<div id="p-vue" class="page active">
  <div class="hero-stat">
    <div class="hero-stat-content">
      <div class="hero-stat-eyebrow">Le dispositif Ergothèque® en France</div>
      <div class="hero-stat-title">Une <span class="accent">réponse intégrée</span> au maintien à domicile, déployée sur l'ensemble du territoire</div>
      <div class="hero-stat-sub">Évaluation à domicile par un·e ergothérapeute · Mise à disposition immédiate et sans reste à charge d'aides techniques · Logique circulaire · Préconisations et conseils pour l'autonomie · Coordination avec l'écosystème du bien-vieillir</div>
    </div>
    <div class="hero-stat-numbers">
      <div class="hero-stat-num"><div class="hero-stat-num-val" id="hero-ergos">31</div><div class="hero-stat-num-lbl">Ergothèques</div></div>
      <div class="hero-stat-num"><div class="hero-stat-num-val" id="hero-benef">—</div><div class="hero-stat-num-lbl">Bénéficiaires</div></div>
      <div class="hero-stat-num"><div class="hero-stat-num-val" id="hero-at">—</div><div class="hero-stat-num-lbl">AT mises à dispo</div></div>
    </div>
  </div>

  <div class="grid gauto mb20" id="kpi-grid"></div>

  <div class="grid g2 mb20">
    <div class="card">
      <div class="block-title">Évolution annuelle — destination des aides techniques préconisées</div>
      <div class="legend mb12">
        <span class="legend-item"><span class="ld" style="background:var(--sage)"></span>Mise à disposition (prêt MJ)</span>
        <span class="legend-item"><span class="ld" style="background:var(--gold)"></span>Achetée par le bénéficiaire</span>
        <span class="legend-item"><span class="ld" style="background:var(--coral-l)"></span>Non acquise</span>
      </div>
      <div class="chart-box" style="height:230px"><canvas id="c-evol"></canvas></div>
    </div>
    <div class="card">
      <div class="block-title">Répartition globale des préconisations</div>
      <div class="legend mb12" id="lgd-donut"></div>
      <div class="chart-box" style="height:230px"><canvas id="c-donut"></canvas></div>
    </div>
  </div>

  <div class="card mb20">
    <div class="flex fac fsp mb12" style="flex-wrap:wrap;gap:12px">
      <div class="block-title" style="margin:0">Comparaison entre ergothèques</div>
      <div class="tabs" style="margin:0">
        <button class="tab on" onclick="switchVueTab(this,'pret')">AT mises à dispo</button>
        <button class="tab" onclick="switchVueTab(this,'taux')">Taux de mise à dispo</button>
        <button class="tab" onclick="switchVueTab(this,'benef')">Bénéficiaires</button>
        <button class="tab" onclick="switchVueTab(this,'recyc')">AT recyclées</button>
      </div>
    </div>
    <div class="chart-box" style="height:260px"><canvas id="c-compare"></canvas></div>
  </div>
</div>

<!-- ══ PERSONNES ══ -->
<div id="p-personnes" class="page">
  <div class="mb24">
    <div class="section-title">Profil des bénéficiaires</div>
    <div class="section-sub">Caractéristiques socio-cliniques des personnes accompagnées</div>
  </div>

function showErgoDetail(code) {
  activeErgoDetail = code; // Mémoriser quelle ergothèque est ouverte
  
  const ergo = DATA.by_ergo[code];
  if (!ergo) return;
  const e = ergo.meta;
  
  // Utiliser les données filtrées par année
  let a;
  if (activeYear !== 'all' && ergo.years[activeYear]) {
    a = ergo.years[activeYear];
  } else {
    a = ergo.all;
  }
  
  document.getElementById('ed-name').textContent = e.titre;
  document.getElementById('ed-badge').innerHTML = `<span class="${e.type === 'bailleur' ? 'type-bailleur' : 'type-dept'}">${e.type === 'bailleur' ? 'Bailleur social' : 'Département'}</span> &nbsp; <span class="fs11 text-mid">${e.region}</span>`;

  const taux = a.total > 0 ? (100*a.pret/a.total) : 0;
  const kpis = [
    {label:'Bénéficiaires', val:fmt(a.benef)},
    {label:'AT mises à dispo', val:fmt(a.pret)},
    {label:'AT achetées', val:fmt(a.achat)},
    {label:'AT non acquises', val:fmt(a.nmep)},
    {label:'AT recyclées', val:fmt(a.recyc)},
    {label:'Taux mise à dispo', val:fmtPct(taux)},
    {label:'Âge moyen', val:a.age_mean ? a.age_mean.toFixed(1).replace('.',',')+' ans' : '—'},
    {label:'Préconisations totales', val:fmt(a.total)}
  ];
  document.getElementById('ed-kpis').innerHTML = kpis.map(k =>
    `<div class="kpi"><div class="kpi-label">${k.label}</div><div class="kpi-value">${k.val}</div></div>`
  ).join('');


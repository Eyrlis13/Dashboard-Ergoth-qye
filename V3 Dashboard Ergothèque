const COL = {
  sage:'#3D7A6A', sageL:'#7FB5A5', sageM:'#5A9E8C', sagePale:'#E8F3F0',
  coral:'#D4714A', coralL:'#F2C4A8', coralPale:'#FBF0EA',
  gold:'#B8903A', goldPale:'#F5EDD6',
  plum:'#7A5C8A', plumPale:'#F0EAF5',
  cream:'#F8F4EE', cream2:'#F0EAE0',
  charcoal:'#2A312E', mid:'#5A6560', light:'#9AADA6'
};
const fmt = n => (n||0).toLocaleString('fr-FR').replace(/,/g,' ').replace(/\u00a0/g,' ');
const fmtPct = n => (n||0).toFixed(1).replace('.',',') + ' %';
const fmtEur = n => Math.round(n).toLocaleString('fr-FR').replace(/,/g,' ') + ' €';
const fmtEurK = n => {
  if (n >= 1e6) return (n/1e6).toFixed(2).replace('.',',') + ' M€';
  if (n >= 1e3) return (n/1e3).toFixed(0) + ' k€';
  return Math.round(n) + ' €';
};


function drawVue() {
  const d = getCurrentData();

  // Hero
  document.getElementById('hero-ergos').textContent = activeErgo ? '1' : DATA.ergos_meta.length;
  document.getElementById('hero-benef').textContent = fmt(d.benef);
  document.getElementById('hero-at').textContent = fmt(d.pret);

  // KPIs
  const tauxPret = d.total > 0 ? (100 * d.pret / d.total) : 0;
  const kpis = [
    {label:'Bénéficiaires accompagnés', val:fmt(d.benef), sub:'Personnes vues à domicile', col:COL.sage},
    {label:'Préconisations totales', val:fmt(d.total), sub:'AT recommandées par les ergos', col:COL.charcoal},
    {label:'Mises à disposition (prêt)', val:fmt(d.pret), sub:'Sans reste à charge', col:COL.sage},
    {label:'Achetées par bénéficiaire', val:fmt(d.achat), sub:'Acquisition par autre voie', col:COL.gold},
    {label:'Préconisées non acquises', val:fmt(d.nmep), sub:'Hors périmètre prêt MJ', col:COL.coral},
    {label:'AT recyclées', val:fmt(d.recyc), sub:'Logique circulaire', col:COL.sageL},
    {label:'Taux de mise à dispo', val:fmtPct(tauxPret), sub:'Part des préconisations couvertes', col:COL.sage},
    {label:'Âge moyen des bénéficiaires', val:d.age_mean ? d.age_mean.toFixed(1).replace('.',',') + ' ans' : '—', sub:'Population vieillissante', col:COL.plum}
  ];
  const grid = document.getElementById('kpi-grid');
  grid.innerHTML = kpis.map(k =>
    `<div class="kpi"><div class="kpi-accent" style="background:${k.col}"></div>
     <div class="kpi-label">${k.label}</div>
     <div class="kpi-value">${k.val}</div>
     <div class="kpi-sub">${k.sub}</div></div>`
  ).join('');

  // Évolution annuelle
  const years = DATA.years;
  const ergoData = activeErgo ? DATA.by_ergo[activeErgo] : null;
  const yearData = years.map(y => {
    if (ergoData) return ergoData.years[y] || {pret:0, achat:0, nmep:0};
    return DATA.by_year[y] || {pret:0, achat:0, nmep:0};
  });

  if (charts.evol) charts.evol.destroy();
  charts.evol = new Chart(document.getElementById('c-evol'), {
    type: 'bar',
    data: {
      labels: years,
      datasets: [
        {label:'Mise à dispo', data:yearData.map(d=>d.pret), backgroundColor:COL.sage, borderRadius:6},
        {label:'Achetée', data:yearData.map(d=>d.achat), backgroundColor:COL.gold, borderRadius:6},
        {label:'Non acquise', data:yearData.map(d=>d.nmep), backgroundColor:COL.coralL, borderRadius:6}
      ]
    },
    options: {
      maintainAspectRatio:false, responsive:true,
      plugins:{legend:{display:false}, tooltip:{callbacks:{label:(c)=>c.dataset.label+': '+fmt(c.parsed.y)}}},
      scales:{
        x:{stacked:true, grid:{display:false}, border:{display:false}},
        y:{stacked:true, grid:{color:'rgba(0,0,0,0.04)'}, border:{display:false}, ticks:{callback:v=>fmt(v)}}
      }
    }
  });

  // Donut répartition
  if (charts.donut) charts.donut.destroy();
  const donutData = [d.pret, d.achat, d.nmep];
  const donutLabels = ['Prêt MJ', 'Acheté bénéficiaire', 'Non acquis'];
  const donutColors = [COL.sage, COL.gold, COL.coralL];
  const total = donutData.reduce((a,b)=>a+b,0);
  charts.donut = new Chart(document.getElementById('c-donut'), {
    type:'doughnut',
    data:{labels:donutLabels, datasets:[{data:donutData, backgroundColor:donutColors, borderWidth:0}]},
    options:{
      maintainAspectRatio:false, cutout:'65%',
      plugins:{legend:{display:false}, tooltip:{callbacks:{label:(c)=>c.label+': '+fmt(c.parsed)+' ('+(100*c.parsed/total).toFixed(1).replace('.',',')+'%)'}}}
    }
  });
  document.getElementById('lgd-donut').innerHTML = donutLabels.map((l,i)=>{
    const pct = total > 0 ? (100*donutData[i]/total).toFixed(1).replace('.',',') : 0;
    return `<span class="legend-item"><span class="ld" style="background:${donutColors[i]}"></span>${l} (${pct}%)</span>`;
  }).join('');

  // Compare
  drawCompare();
}

function switchVueTab(btn, tab) {
  document.querySelectorAll('#p-vue .tabs .tab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  activeVueTab = tab;
  drawCompare();
}

function drawCompare() {
  const ergos = DATA.ergos_meta;
  // Filtrer par année si une année spécifique est sélectionnée
  const ergoData = ergos.map(e => {
    const ergo = DATA.by_ergo[e.code];
    if (activeYear !== 'all' && ergo.years && ergo.years[activeYear]) {
      return ergo.years[activeYear];
    }
    return ergo.all;
  });

  let values, label, color;
  if (activeVueTab === 'pret') {
    values = ergoData.map(d => d.pret); label = 'AT mises à dispo'; color = COL.sage;
  } else if (activeVueTab === 'taux') {
    values = ergoData.map(d => d.total > 0 ? (100*d.pret/d.total) : 0); label = 'Taux mise à dispo (%)'; color = COL.sageM;
  } else if (activeVueTab === 'benef') {
    values = ergoData.map(d => d.benef); label = 'Bénéficiaires'; color = COL.coral;
  } else {
    values = ergoData.map(d => d.recyc); label = 'AT recyclées'; color = COL.gold;
  }

  // Trier par valeur descendante
  const sorted = ergos.map((e,i) => ({code:e.code, label:e.nom, value:values[i], type:e.type})).sort((a,b)=>b.value-a.value);
  const labels = sorted.map(s => s.label.length > 18 ? s.label.slice(0,17)+'…' : s.label);
  const vals = sorted.map(s => s.value);
  const colors = sorted.map(s => s.type === 'bailleur' ? COL.gold : color);

  if (charts.compare) charts.compare.destroy();
  charts.compare = new Chart(document.getElementById('c-compare'), {
    type:'bar',
    data:{labels, datasets:[{label, data:vals, backgroundColor:colors, borderRadius:5}]},
    options:{
      maintainAspectRatio:false, indexAxis:'x',
      plugins:{legend:{display:false}, tooltip:{callbacks:{label:(c)=>label+': '+(activeVueTab==='taux'?fmtPct(c.parsed.y):fmt(c.parsed.y))}}},
      scales:{
        x:{grid:{display:false}, border:{display:false}, ticks:{font:{size:9}, maxRotation:60, minRotation:50}},
        y:{grid:{color:'rgba(0,0,0,0.04)'}, border:{display:false}, ticks:{callback:v=>activeVueTab==='taux'?v+'%':fmt(v)}}
      }
    }
  });
}



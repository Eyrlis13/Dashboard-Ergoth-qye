    },
    options:{
      maintainAspectRatio:false, indexAxis:'y',
      plugins:{legend:{display:false}, tooltip:{callbacks:{label:(c)=>fmt(c.parsed.x)+' AT'}}},
      scales:{
        x:{grid:{color:'rgba(0,0,0,0.04)'}, border:{display:false}, ticks:{callback:v=>fmt(v)}},
        y:{grid:{display:false}, border:{display:false}, ticks:{font:{size:11}}}
      }

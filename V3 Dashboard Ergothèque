//  POPULATE ERGO FILTER
// ════════════════════════════════════════
function populateErgoFilter() {
  const sel = document.getElementById('f-ergo');
  DATA.ergos_meta.forEach(e => {
    const opt = document.createElement('option');
    opt.value = e.code;
    opt.textContent = e.titre.replace('ERGOTHÈQUE ', '').slice(0, 45);
    sel.appendChild(opt);
  });
}


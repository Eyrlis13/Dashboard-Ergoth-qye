    </div>`;
  }).join('');
}

function _vfEscAttr(s) {
  return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function drawErgosResearch() {
  const verbs = DATA.verbatims_ergos;
  const sthemes_par_theme = DATA.ergo_sous_themes_par_theme;
  const ctx_lex = DATA.ergo_contextes_lex;

  // === FILTRES PAR THÈME ===
  const themes = Object.keys(sthemes_par_theme).sort();
  let html_theme = `<span class="vf-pill ${activeTheme === null ? 'on' : ''}" data-vf-type="theme" data-vf-value="">Tous <span class="vf-count">(${verbs.length})</span></span>`;
  themes.forEach(t => {
    const n = verbs.filter(v => v.theme === t).length;
    const cls = THEME_COLORS[t] || 'sage';
    const onCls = activeTheme === t ? `on ${cls}` : '';
    html_theme += `<span class="vf-pill ${onCls}" data-vf-type="theme" data-vf-value="${_vfEscAttr(t)}">${_vfEscAttr(t)} <span class="vf-count">(${n})</span></span>`;
  });
  document.getElementById('vf-theme').innerHTML = html_theme;

  // === FILTRES PAR SOUS-THÈME (dépendant du thème actif) ===
  let sthemes_dispo;
  if (activeTheme) {
    sthemes_dispo = sthemes_par_theme[activeTheme] || [];
  } else {
    sthemes_dispo = [...new Set(verbs.map(v => v.sous_theme))].sort();
  }

  const n_total_for_st = activeTheme
    ? verbs.filter(v => v.theme === activeTheme).length
    : verbs.length;

  let html_st = `<span class="vf-pill ${activeSousTheme === null ? 'on' : ''}" data-vf-type="sstheme" data-vf-value="">Tous <span class="vf-count">(${n_total_for_st})</span></span>`;
  sthemes_dispo.forEach(st => {
    const n = activeTheme
      ? verbs.filter(v => v.theme === activeTheme && v.sous_theme === st).length
      : verbs.filter(v => v.sous_theme === st).length;
    if (n === 0) return;
    const onCls = activeSousTheme === st ? 'on' : '';
    html_st += `<span class="vf-pill ${onCls}" data-vf-type="sstheme" data-vf-value="${_vfEscAttr(st)}">${_vfEscAttr(st)} <span class="vf-count">(${n})</span></span>`;
  });
  document.getElementById('vf-sstheme').innerHTML = html_st;

  // === FILTRES PAR CONTEXTE ===
  const contextes = Object.keys(ctx_lex);
  let html_ctx = `<span class="vf-pill ${activeContexte === null ? 'on' : ''}" data-vf-type="contexte" data-vf-value="">Tous</span>`;
  contextes.forEach(c => {
    const n = verbs.filter(v => v.contexte === c).length;
    if (n === 0) return;
    const onCls = activeContexte === c ? 'on' : '';
    const lbl = c.replace(/_/g, ' ');
    html_ctx += `<span class="vf-pill ${onCls}" data-vf-type="contexte" data-vf-value="${_vfEscAttr(c)}" title="${_vfEscAttr(ctx_lex[c])}">${_vfEscAttr(lbl)} <span class="vf-count">(${n})</span></span>`;
  });
  document.getElementById('vf-contexte').innerHTML = html_ctx;

  // === APPLIQUER LES FILTRES ===
  let filtered = verbs;
  if (activeTheme) filtered = filtered.filter(v => v.theme === activeTheme);
  if (activeSousTheme) filtered = filtered.filter(v => v.sous_theme === activeSousTheme);
  if (activeContexte) filtered = filtered.filter(v => v.contexte === activeContexte);

  // === COMPTEUR ===
  const counter = document.getElementById('vf-counter');
  if (filtered.length === verbs.length) {
    counter.textContent = `${verbs.length} verbatims affichés`;
  } else {
    counter.textContent = `${filtered.length} / ${verbs.length} verbatims (filtré)`;
  }

  // === AFFICHER LES VERBATIMS ===
  const escapeHtml = (s) => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  const grid = document.getElementById('verbatim-grid');
  if (filtered.length === 0) {
    grid.innerHTML = '<div class="card text-mid fs13" style="grid-column:1/-1;text-align:center;padding:30px">Aucun verbatim ne correspond à ces filtres.</div>';
  } else {
    grid.innerHTML = filtered.map(v => {
      const themeColor = THEME_COLORS[v.theme] || 'sage';
      const ctxLabel = v.contexte.replace(/_/g, ' ');
      return `<div class="vbcard">
        <div class="vbcard-text">${escapeHtml(v.text)}</div>
        <div class="vbcard-meta">
          <span class="vbcard-code">${escapeHtml(v.code)}</span>
          <span class="vbcard-ctx">${escapeHtml(ctxLabel)}</span>
          <span style="color:var(--light)">·</span>
          <span class="vbcard-theme" style="background:var(--${themeColor}-pale);color:var(--${themeColor})">${escapeHtml(v.theme)}</span>
          <span class="vbcard-stheme">${escapeHtml(v.sous_theme)}</span>
        </div>
      </div>`;
    }).join('');
  }
}

function setVerbatimFilter(type, value) {
  // value === '' ou null signifie "Tous"
  if (value === '' || value === null) value = null;
  if (type === 'theme') {
    activeTheme = value;
    if (activeSousTheme && value) {
      const sts = DATA.ergo_sous_themes_par_theme[value] || [];
      if (!sts.includes(activeSousTheme)) activeSousTheme = null;
    }
  }
  else if (type === 'sstheme') activeSousTheme = value;
  else if (type === 'contexte') activeContexte = value;
  drawErgosResearch();
}

// Event delegation pour les pills de filtre verbatim
// Une seule fois : on attache au document, ça gère tous les clics même après re-render
if (!window._vfDelegationAttached) {
  document.addEventListener('click', function(e) {
    const pill = e.target.closest('.vf-pill[data-vf-type]');
    if (!pill) return;
    const type = pill.getAttribute('data-vf-type');
    const value = pill.getAttribute('data-vf-value');
    setVerbatimFilter(type, value);
  });
  window._vfDelegationAttached = true;
}

// ════════════════════════════════════════
//  DRAW PAGE
// ════════════════════════════════════════
function drawPage(view) {
  if (view === 'vue') drawVue();
  if (view === 'personnes') drawPersonnes();
  if (view === 'equipement') drawEquipement();
  if (view === 'sroi') calcSROI();
  if (view === 'ergotheques') drawErgotheques();
  if (view === 'recherche') {
    // Default to first tab (aines)
  }
}

// ════════════════════════════════════════
//  INIT
// ════════════════════════════════════════
populateErgoFilter();
drawVue();
</script>

    const atShort = at.length > 60 ? at.slice(0,59)+'…' : at;
    return `<div class="stat-row">
      <div class="stat-label" style="font-size:12px">${atShort}</div>
      <div class="stat-bar-wrap" style="width:240px"><div class="stat-bar-fill" style="width:${pct}%;background:${COL.coralL}"></div></div>
      <div class="stat-pct">${fmt(n)}</div>
    </div>`;
  }).join('');
}

function switchEqTab(btn, tab) {
  document.querySelectorAll('#p-equipement .tabs .tab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  activeEqTab = tab;
  drawEqCross();
}

function _getGranularData() {
  // Renvoie l'agrégat granulaire selon les filtres actifs
  if (activeErgo && activeYear !== 'all') {
    const e = DATA.granular_by_ergo_year[activeErgo];
    if (e && e[activeYear]) return e[activeYear];
    return null;
  }
  if (activeErgo) {
    return DATA.granular_by_ergo[activeErgo] || null;
  }
  if (activeYear !== 'all') {
    return DATA.granular_by_year[activeYear] || null;
  }
  return DATA.granular_global;
}

function drawEqCross() {
  const g = _getGranularData();
  const canvas = document.getElementById('c-eq-cross');
  const insightEl = document.getElementById('eq-cross-insight');

  if (!g || g.n_benef === 0) {
    if (charts.eqCross) charts.eqCross.destroy();
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    insightEl.innerHTML = '<strong>Aucune donnée</strong> pour ce filtre.';
    return;
  }

  let labels, raw, dimLabel;
  if (activeEqTab === 'gir') {
    const order = ['GIR 1','GIR 2','GIR 3','GIR 4','GIR 5','GIR 6','Non renseigné'];
    labels = order.filter(k => g.by_gir[k]);
    raw = labels.map(k => g.by_gir[k]);
    dimLabel = 'GIR';
  } else if (activeEqTab === 'age') {
    const order = ['<60','60-69','70-79','80-89','90+','Non renseigné'];
    labels = order.filter(k => g.by_age[k]);
    raw = labels.map(k => g.by_age[k]);
    dimLabel = 'âge';
  } else if (activeEqTab === 'orient') {
    const order = ['Conseil Départemental','CARSAT','Bailleur social','DAC','Auto-orientation Ergothèque','Autre','Non renseigné'];
    labels = order.filter(k => g.by_orient[k]);
    raw = labels.map(k => g.by_orient[k]);
    dimLabel = 'orienteur';
  } else {
    // isolement
    const order = ['Oui','Non','Non renseigné'];
    labels = order.filter(k => g.by_iso[k]).map(k => k === 'Oui' ? 'Isolé' : (k === 'Non' ? 'Non isolé' : 'Non renseigné'));
    const keys = order.filter(k => g.by_iso[k]);
    raw = keys.map(k => g.by_iso[k]);
    dimLabel = 'isolement';
  }

  // Calculer pourcentages destination pour chaque catégorie
  const data = raw.map(r => {
    const tot = r.pret + r.achat + r.nmep;
    return {
      pret_pct: tot > 0 ? 100 * r.pret / tot : 0,
      achat_pct: tot > 0 ? 100 * r.achat / tot : 0,
      nmep_pct: tot > 0 ? 100 * r.nmep / tot : 0,
      n_benef: r.n_benef,
      n_pret: r.pret,
      n_achat: r.achat,
      n_nmep: r.nmep,
    };
  });

  if (charts.eqCross) charts.eqCross.destroy();
  charts.eqCross = new Chart(canvas, {
    type:'bar',
    data:{
      labels,
      datasets:[
        {label:'Prêt MJ', data:data.map(x=>x.pret_pct), backgroundColor:COL.sage, borderRadius:5, stack:'a'},
        {label:'Acheté', data:data.map(x=>x.achat_pct), backgroundColor:COL.gold, borderRadius:5, stack:'a'},
        {label:'Non acquis', data:data.map(x=>x.nmep_pct), backgroundColor:COL.coralL, borderRadius:5, stack:'a'}
      ]
    },
    options:{
      maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{
          callbacks:{
            title:(items)=>{
              const i = items[0].dataIndex;
              return labels[i] + ' — ' + fmt(data[i].n_benef) + ' bénéficiaires';
            },
            label:(c)=>{
              const i = c.dataIndex;
              const ds = c.dataset.label;
              const n = ds === 'Prêt MJ' ? data[i].n_pret : (ds === 'Acheté' ? data[i].n_achat : data[i].n_nmep);
              return ds + ' : ' + fmtPct(c.parsed.y) + ' (' + fmt(n) + ' AT)';
            }
          }
        }
      },
      scales:{
        x:{stacked:true, grid:{display:false}, border:{display:false}, ticks:{font:{size:10}}},
        y:{stacked:true, max:100, grid:{color:'rgba(0,0,0,0.04)'}, border:{display:false}, ticks:{callback:v=>v+'%'}}
      }
    }
  });

  // Insight contextualisé
  const ergoLabel = activeErgo ? (DATA.ergos_meta.find(e=>e.code===activeErgo)?.nom || activeErgo) : 'l\'ensemble du dispositif';
  const yearLabel = activeYear !== 'all' ? ' en ' + activeYear : '';
  const totalPretPct = g.total_pret + g.total_achat + g.total_nmep > 0 ? 100 * g.total_pret / (g.total_pret + g.total_achat + g.total_nmep) : 0;
  insightEl.innerHTML = '<strong>Lecture · </strong> Sur ' + ergoLabel + yearLabel + ', ' + fmt(g.n_benef) + ' bénéficiaires sont répartis par ' + dimLabel + '. Le taux global de mise à disposition est de <strong>' + fmtPct(totalPretPct) + '</strong>. Les ratios prêt/achat/non-acquis sont calculés au sein de chaque sous-groupe (vrai croisement des données).';
}



  </div>
</aside>

<!-- ══════════ MAIN ══════════ -->
<div class="main">
<div class="topbar">
  <div class="topbar-title" id="topbar-title">Vue d'ensemble</div>
  <div class="topbar-filters">
    <span class="filter-label">Ergothèque</span>
    <select class="filter-select" id="f-ergo" onchange="applyFilters()"><option value="">Toutes</option></select>
    <span class="filter-label">Année</span>
    <select class="filter-select" id="f-year" onchange="applyFilters()">
      <option value="all" selected>Toutes</option>

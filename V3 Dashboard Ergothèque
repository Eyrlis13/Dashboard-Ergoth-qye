function go(view) {
  currentView = view;
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('p-' + view).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  event.target.closest('.nav-item').classList.add('active');
  const titles = {vue:"Vue d'ensemble", personnes:'Personnes', equipement:'Équipement & modèle', sroi:'Coût évité & SROI', ergotheques:'Ergothèques', recherche:'Enquêtes & entretiens'};
  document.getElementById('topbar-title').textContent = titles[view];
  drawPage(view);
}

function applyFilters() {
  activeErgo = document.getElementById('f-ergo').value;
  activeYear = document.getElementById('f-year').value;
  // Update badge
  const badge = document.getElementById('filter-badge');
  let txt = '';
  if (activeErgo) {
    const meta = DATA.ergos_meta.find(e => e.code === activeErgo);
    txt = meta ? meta.titre.replace('ERGOTHÈQUE ', 'EGT ') : activeErgo;
  } else {
    txt = `${DATA.ergos_meta.length} ergothèques`;
  }
  if (activeYear !== 'all') txt += ' · ' + activeYear;
  badge.textContent = txt;
  drawPage(currentView);
  
  // Si panneau détail ergothèque ouvert, le rafraîchir
  if (activeErgoDetail) {
    showErgoDetail(activeErgoDetail);
  }
}

// ════════════════════════════════════════
//  DATA SELECTION
// ════════════════════════════════════════
function getCurrentData() {
  // Renvoie les agrégats correspondant aux filtres actifs
  if (activeErgo) {
    const ergo = DATA.by_ergo[activeErgo];
    if (!ergo) return DATA.global;
    if (activeYear !== 'all') {
      return ergo.years[activeYear] || ergo.all;
    }
    return ergo.all;
  }
  if (activeYear !== 'all') {
    return DATA.by_year[activeYear] || DATA.global;
  }
  return DATA.global;
}


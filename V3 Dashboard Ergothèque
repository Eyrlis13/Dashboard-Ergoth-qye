  });

  // Top non acquises (granulaire)
  const _topNmepObj = (_g_eq && _g_eq.top_nmep) ? _g_eq.top_nmep : {};
  const topN = Object.entries(_topNmepObj).sort((a,b)=>b[1]-a[1]).slice(0,10);
  const maxN = topN.length > 0 ? topN[0][1] : 1;
  document.getElementById('top-nmep-bars').innerHTML = topN.length === 0 ? '<div class="text-mid fs12" style="padding:20px;text-align:center">Aucune donnée</div>' : topN.map(([at,n]) => {

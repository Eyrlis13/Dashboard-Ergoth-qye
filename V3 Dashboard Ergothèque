  charts.edProfil = new Chart(document.getElementById('c-ed-profil'), {
    type:'doughnut',
    data:{labels:girK.map(k=>'GIR '+k), datasets:[{data:girV, backgroundColor:['#7A2D1A','#C04E2A','#D4714A','#B8903A','#7FB5A5','#5A9E8C'], borderWidth:0}]},
    options:{maintainAspectRatio:false, cutout:'58%', plugins:{legend:{position:'right', labels:{boxWidth:10, font:{size:10}, padding:5}}}}
  });

  document.getElementById('ergo-detail').style.display = 'block';
  document.getElementById('ergo-detail').scrollIntoView({behavior:'smooth', block:'start'});
}


      </div>
      <div class="grid g3 mb16"><div class="kpi-mini">
                <div class="kpi-mini-accent" style="background:var(--sage)"></div>
                <div class="kpi-mini-label">Idée structurelle #1</div>
                <div class="kpi-mini-value">Ergothèque nationale</div>
                <div class="kpi-mini-detail">Mutualiser les AT spécifiques/coûteuses</div>
            </div><div class="kpi-mini">

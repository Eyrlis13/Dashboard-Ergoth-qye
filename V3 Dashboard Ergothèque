function calcSROI() {
  const coutChute = +document.getElementById('s-cout-chute').value;
  const pctGrave = +document.getElementById('s-pct-grave').value / 100;
  const reduc = +document.getElementById('s-reduc').value / 100;
  const pctRisque = +document.getElementById('s-pct-risque').value / 100;
  const incid = +document.getElementById('s-incid').value;
  const aideHum = +document.getElementById('s-aide-hum').value;
  const pctAuto = +document.getElementById('s-pct-auto').value / 100;
  const coutBen = +document.getElementById('s-cout-ben').value;

  // Update displays
  document.getElementById('v-cout-chute').textContent = fmtEur(coutChute);
  document.getElementById('v-pct-grave').textContent = (pctGrave*100).toFixed(0)+' %';
  document.getElementById('v-reduc').textContent = (reduc*100).toFixed(0)+' %';
  document.getElementById('v-pct-risque').textContent = (pctRisque*100).toFixed(0)+' %';
  document.getElementById('v-incid').textContent = incid.toFixed(2).replace('.',',') + ' /an';
  document.getElementById('v-aide-hum').textContent = fmtEur(aideHum);
  document.getElementById('v-pct-auto').textContent = (pctAuto*100).toFixed(0)+' %';
  document.getElementById('v-cout-ben').textContent = fmtEur(coutBen);

  const benef = DATA.global.benef;

  // Coût évité chutes :
  // bénéficiaires à risque × incidence chute/an × % chute grave × coût d'une chute grave × % réduction grâce à l'ergo
  const beneficR = benef * pctRisque;
  const chutesGravesEvitees = beneficR * incid * pctGrave * reduc;
  const coutEviteChutes = chutesGravesEvitees * coutChute;

  // Aides humaines évitées
  const aidesEv = benef * pctAuto * aideHum;

  // Total
  const valeurTotale = coutEviteChutes + aidesEv;
  const coutTotal = benef * coutBen;
  const ratio = coutTotal > 0 ? valeurTotale / coutTotal : 0;

  document.getElementById('sroi-ratio').textContent = ratio.toFixed(2).replace('.',',') + ' €';
  document.getElementById('sroi-chutes').textContent = fmtEurK(coutEviteChutes);
  document.getElementById('sroi-aides').textContent = fmtEurK(aidesEv);
  document.getElementById('sroi-cout').textContent = fmtEurK(coutTotal);
  document.getElementById('sroi-valeur').textContent = fmtEurK(valeurTotale);

  // Pie
  if (charts.sroiPie) charts.sroiPie.destroy();
  const pieData = [coutEviteChutes, aidesEv];
  const pieTot = pieData.reduce((a,b)=>a+b,0);
  charts.sroiPie = new Chart(document.getElementById('c-sroi-pie'), {
    type:'doughnut',
    data:{labels:['Coût évité chutes','Aides humaines évitées'], datasets:[{data:pieData, backgroundColor:[COL.coral, COL.sage], borderWidth:0}]},
    options:{
      maintainAspectRatio:false, cutout:'62%',
      plugins:{legend:{display:false}, tooltip:{callbacks:{label:(c)=>c.label+': '+fmtEurK(c.parsed)+' ('+(pieTot>0?(100*c.parsed/pieTot).toFixed(0):0)+'%)'}}}
    }
  });
  document.getElementById('lgd-sroi').innerHTML = `
    <span class="legend-item"><span class="ld" style="background:${COL.coral}"></span>Coût évité chutes (${pieTot>0?(100*coutEviteChutes/pieTot).toFixed(0):0}%)</span>
    <span class="legend-item"><span class="ld" style="background:${COL.sage}"></span>Aides humaines évitées (${pieTot>0?(100*aidesEv/pieTot).toFixed(0):0}%)</span>`;

  // Scénarios (variation ±30%)
  if (charts.sroiScen) charts.sroiScen.destroy();
  const scenLow = ratio * 0.7;
  const scenMid = ratio;
  const scenHigh = ratio * 1.3;
  charts.sroiScen = new Chart(document.getElementById('c-sroi-scen'), {
    type:'bar',
    data:{
      labels:['Conservateur','Central','Optimiste'],
      datasets:[{
        data:[scenLow, scenMid, scenHigh],
        backgroundColor:[COL.coralL, COL.sageM, COL.sage],
        borderRadius:6
      }]
    },
    options:{
      maintainAspectRatio:false, indexAxis:'y',
      plugins:{legend:{display:false}, tooltip:{callbacks:{label:(c)=>'1 € investi → '+c.parsed.x.toFixed(2).replace('.',',')+' € de valeur'}}},
      scales:{
        x:{grid:{color:'rgba(0,0,0,0.04)'}, border:{display:false}, ticks:{callback:v=>v+' €'}},
        y:{grid:{display:false}, border:{display:false}}
      }
    }
  });
}


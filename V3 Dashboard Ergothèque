
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ergothèque® — Tableau de bord Merci Julie · V3</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root{
  --cream:#F8F4EE;--cream2:#F0EAE0;--cream3:#E8DFD0;
  --coral:#D4714A;--coral-l:#F2C4A8;--coral-pale:#FBF0EA;
  --sage:#3D7A6A;--sage-l:#7FB5A5;--sage-pale:#E8F3F0;--sage-mid:#5A9E8C;
  --charcoal:#2A312E;--mid:#5A6560;--light:#9AADA6;
  --gold:#B8903A;--gold-pale:#F5EDD6;
  --plum:#7A5C8A;--plum-pale:#F0EAF5;
  --border:rgba(61,122,106,0.13);--border2:rgba(61,122,106,0.25);
  --sh:0 2px 12px rgba(42,49,46,0.07);--sh2:0 6px 32px rgba(42,49,46,0.11);
  --r:10px;--r2:16px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--cream);color:var(--charcoal);font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.6;min-height:100vh}
button{cursor:pointer;font-family:'DM Sans',sans-serif}
select,input,textarea{font-family:'DM Sans',sans-serif}
a{color:var(--sage);text-decoration:none}
a:hover{text-decoration:underline}

.app{display:flex;min-height:100vh}
.sidebar{width:230px;min-width:230px;background:var(--charcoal);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;overflow-y:auto}
.main{margin-left:230px;flex:1;display:flex;flex-direction:column;min-height:100vh}
.topbar{background:white;border-bottom:1px solid var(--border);padding:14px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;gap:16px;flex-wrap:wrap}
.page{padding:32px;flex:1;display:none}
.page.active{display:block}

/* SIDEBAR */
.sb-header{padding:28px 24px 20px;border-bottom:1px solid rgba(255,255,255,0.08)}
.sb-logo{font-family:'Playfair Display',serif;font-size:19px;color:white;letter-spacing:0.02em;line-height:1.2}
.sb-logo span{color:#F2C4A8;font-style:italic}
.sb-sub{font-size:10px;color:var(--light);margin-top:4px;letter-spacing:0.07em;text-transform:uppercase}
.sb-nav{padding:16px 12px;flex:1}
.nav-section{font-size:10px;color:rgba(255,255,255,0.28);letter-spacing:0.08em;text-transform:uppercase;padding:14px 12px 6px;font-weight:500}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;color:rgba(255,255,255,0.6);font-size:13px;transition:all .15s;margin-bottom:2px;cursor:pointer;border:none;background:transparent;width:100%;text-align:left}
.nav-item:hover{background:rgba(255,255,255,0.07);color:white}
.nav-item.active{background:var(--sage);color:white;font-weight:500}
.nav-icon{width:16px;height:16px;flex-shrink:0;opacity:.75}
.nav-item.active .nav-icon{opacity:1}
.sb-footer{padding:18px 24px;border-top:1px solid rgba(255,255,255,0.07)}
.sb-version{font-size:10px;color:rgba(255,255,255,0.32);line-height:1.6}

/* TOPBAR */
.topbar-title{font-family:'Playfair Display',serif;font-size:17px;font-weight:500;color:var(--charcoal);white-space:nowrap}
.topbar-filters{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.filter-label{font-size:10px;color:var(--mid);font-weight:500;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap}
.filter-select{background:var(--cream);border:1px solid var(--border2);border-radius:7px;padding:6px 10px;font-size:12px;color:var(--charcoal);outline:none;cursor:pointer}
.filter-badge{background:var(--sage-pale);color:var(--sage);font-size:11px;font-weight:500;padding:4px 10px;border-radius:20px;border:1px solid var(--border2);white-space:nowrap}

/* HEADINGS */
.section-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:500;color:var(--charcoal);line-height:1.2}
.section-sub{font-size:13px;color:var(--mid);margin-top:4px}
.block-title{font-size:10px;font-weight:500;color:var(--mid);text-transform:uppercase;letter-spacing:.07em;margin-bottom:12px}
.subblock-title{font-family:'Playfair Display',serif;font-size:16px;font-weight:500;color:var(--charcoal);margin-bottom:6px}
.eyebrow{font-size:10px;font-weight:500;color:var(--coral);text-transform:uppercase;letter-spacing:.08em}

/* GRIDS */
.grid{display:grid;gap:16px}
.g2{grid-template-columns:repeat(2,1fr)}
.g3{grid-template-columns:repeat(3,1fr)}
.g4{grid-template-columns:repeat(4,1fr)}
.gauto{grid-template-columns:repeat(auto-fit,minmax(175px,1fr))}
@media(max-width:1100px){.g4{grid-template-columns:repeat(2,1fr)}.g3{grid-template-columns:repeat(2,1fr)}}
@media(max-width:680px){.g2,.g3,.g4,.gauto{grid-template-columns:1fr}}

/* CARDS */
.card{background:white;border:1px solid var(--border);border-radius:var(--r2);padding:20px;box-shadow:var(--sh)}
.card-flush{background:white;border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;box-shadow:var(--sh)}
.card-feature{background:linear-gradient(135deg,var(--sage-pale),var(--cream));border:1px solid var(--border2);border-radius:var(--r2);padding:22px 26px;box-shadow:var(--sh)}

/* KPI */
.kpi{background:white;border:1px solid var(--border);border-radius:var(--r2);padding:18px 20px;box-shadow:var(--sh);position:relative;overflow:hidden}
.kpi-accent{position:absolute;top:0;left:0;width:3px;height:100%}
.kpi-label{font-size:10px;font-weight:500;color:var(--mid);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.kpi-value{font-family:'Playfair Display',serif;font-size:26px;font-weight:500;line-height:1;color:var(--charcoal)}
.kpi-sub{font-size:11px;color:var(--light);margin-top:5px}

/* CHART */
.chart-box{position:relative;width:100%}

/* LEGEND */
.legend{display:flex;flex-wrap:wrap;gap:12px}
.legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--mid)}
.ld{width:9px;height:9px;border-radius:2px;flex-shrink:0}

/* TABS */
.tabs{display:flex;gap:3px;background:var(--cream2);padding:3px;border-radius:8px;width:fit-content}
.tab{padding:6px 14px;border-radius:6px;border:none;background:transparent;color:var(--mid);font-size:11px;font-weight:500;transition:all .15s;cursor:pointer;white-space:nowrap}
.tab.on{background:white;color:var(--charcoal);box-shadow:var(--sh)}

/* PROFILE BARS */
.profile-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.profile-label{font-size:12px;color:var(--mid);width:160px;flex-shrink:0}
.profile-bar-wrap{flex:1;background:var(--cream2);border-radius:4px;height:8px;overflow:hidden}
.profile-bar{height:8px;border-radius:4px;background:var(--sage)}
.profile-pct{font-size:11px;font-weight:500;color:var(--charcoal);width:48px;text-align:right}

/* SCORE BADGE */
.score-badge{display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:50%;font-family:'Playfair Display',serif;font-size:15px;font-weight:500}
.score-ok{background:var(--sage-pale);color:var(--sage)}
.score-warn{background:var(--gold-pale);color:var(--gold)}
.score-alert{background:var(--coral-pale);color:var(--coral)}

/* TABLE */
.data-table{width:100%;border-collapse:collapse}
.data-table th{font-size:10px;font-weight:500;color:var(--mid);text-transform:uppercase;letter-spacing:.05em;padding:11px 14px;text-align:left;border-bottom:1px solid var(--border2);background:var(--cream);white-space:nowrap;position:sticky;top:0}
.data-table td{padding:12px 14px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle}
.data-table tr:last-child td{border-bottom:none}
.data-table tr:hover td{background:var(--cream)}
.type-dept{background:var(--sage-pale);color:var(--sage);font-size:10px;font-weight:500;padding:2px 8px;border-radius:10px;display:inline-block}
.type-bailleur{background:var(--gold-pale);color:var(--gold);font-size:10px;font-weight:500;padding:2px 8px;border-radius:10px;display:inline-block}
.mini-bar{background:var(--cream2);border-radius:3px;height:5px;overflow:hidden;width:90px}
.mini-bar-fill{height:5px;border-radius:3px;background:var(--sage-l)}

/* SROI */
.slider-row{display:flex;align-items:center;gap:14px;margin-bottom:14px;flex-wrap:wrap}
.slider-label{font-size:13px;color:var(--charcoal);flex:1;min-width:200px;line-height:1.5}
.slider-label small{display:block;font-size:10px;color:var(--light);margin-top:2px;line-height:1.5}
.slider-label small.guide{color:var(--gold);font-style:italic}
.slider-input{flex:1;min-width:100px;accent-color:var(--sage)}
.slider-val{font-size:12px;font-weight:600;color:var(--sage);width:78px;text-align:right;white-space:nowrap;font-variant-numeric:tabular-nums}
.sroi-result{background:var(--charcoal);color:white;border-radius:var(--r2);padding:28px 28px 24px}
.sroi-result-eyebrow{font-size:10px;letter-spacing:.08em;text-transform:uppercase;opacity:.5;margin-bottom:6px}
.sroi-result-value{font-family:'Playfair Display',serif;font-size:48px;font-weight:500;line-height:1;color:#F2C4A8}
.sroi-result-unit{font-size:13px;opacity:.65;margin-top:6px}
.sroi-items{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:20px}
.sroi-item{background:rgba(255,255,255,0.07);border-radius:var(--r);padding:14px}
.sroi-item-label{font-size:10px;opacity:.55;text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
.sroi-item-value{font-family:'Playfair Display',serif;font-size:18px;font-weight:500}

/* BIBLIO */
.biblio-list{font-size:11px;color:var(--mid);line-height:1.6}
.biblio-list li{margin-bottom:6px;padding-left:14px;position:relative;list-style:none}
.biblio-list li::before{content:"›";position:absolute;left:0;color:var(--gold);font-weight:600}
.biblio-list a{color:var(--sage);font-weight:500}

/* VERBATIM */
.verbatim-card{background:white;border:1px solid var(--border);border-radius:var(--r2);padding:22px 22px 16px;box-shadow:var(--sh);position:relative}
.verbatim-card::before{content:'\201C';font-family:'Playfair Display',serif;font-size:62px;color:var(--sage-pale);position:absolute;top:6px;left:14px;line-height:1}
.verbatim-text{font-size:13px;color:var(--charcoal);line-height:1.75;padding-top:18px;font-style:italic}
.verbatim-meta{margin-top:12px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.verbatim-who{font-size:10px;font-weight:600;color:var(--mid);text-transform:uppercase;letter-spacing:.04em}
.vtheme{font-size:10px;padding:2px 8px;border-radius:10px;background:var(--coral-pale);color:var(--coral);font-weight:500}

/* STAT BARS */
.stat-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.stat-label{font-size:12px;color:var(--charcoal);flex:1}
.stat-bar-wrap{width:180px;background:var(--cream2);border-radius:4px;height:8px;overflow:hidden;flex-shrink:0}
.stat-bar-fill{height:8px;border-radius:4px;background:var(--sage)}
.stat-pct{font-size:11px;font-weight:600;color:var(--sage);width:42px;text-align:right;font-variant-numeric:tabular-nums}

/* THEME PILLS */
.theme-pill{display:inline-flex;align-items:center;gap:4px;padding:6px 12px;border-radius:20px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid transparent;transition:all .12s;margin:2px;white-space:nowrap}
.theme-pill.on{background:var(--sage);color:white;border-color:var(--sage)}
.theme-pill:not(.on){background:var(--cream2);color:var(--mid);border-color:var(--border2)}
.theme-pill:not(.on):hover{background:white;color:var(--charcoal)}

/* DETAIL */
.detail-panel{background:white;border:1px solid var(--border2);border-radius:var(--r2);padding:24px;margin-top:20px;box-shadow:var(--sh2)}

/* LIKERT BARS */
.likert-row{margin-bottom:18px}
.likert-label{font-size:12px;color:var(--charcoal);margin-bottom:5px;font-weight:500;display:flex;justify-content:space-between;align-items:center}
.likert-label .likert-n{font-size:10px;color:var(--light);font-weight:400}
.likert-bar{display:flex;height:18px;border-radius:5px;overflow:hidden;background:var(--cream2)}
.likert-seg{display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:white;transition:all .2s}
.likert-seg:hover{filter:brightness(1.08)}
.likert-legend{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:14px;padding:8px 12px;background:var(--cream);border-radius:8px}

/* STAGE / CIRCULAR ECONOMY */
.stage-flow{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:14px 0}
.stage-item{background:var(--cream);border:1px solid var(--border);border-radius:12px;padding:14px;text-align:center;position:relative}
.stage-item.recyc{background:linear-gradient(135deg,var(--sage-pale),var(--cream));border-color:var(--sage-l)}
.stage-num{font-family:'Playfair Display',serif;font-size:24px;font-weight:500;color:var(--sage);line-height:1}
.stage-label{font-size:10px;color:var(--mid);text-transform:uppercase;letter-spacing:.04em;margin-top:6px}
.stage-arrow{position:absolute;top:50%;right:-14px;width:16px;color:var(--light);font-size:18px;transform:translateY(-50%)}
@media(max-width:720px){.stage-flow{grid-template-columns:1fr 1fr}.stage-arrow{display:none}}

/* RAISON BARS */
.raison-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px}
.raison-card{background:var(--cream);border:1px solid var(--border);border-radius:10px;padding:14px}
.raison-num{font-family:'Playfair Display',serif;font-size:22px;font-weight:500;color:var(--charcoal)}
.raison-label{font-size:11px;color:var(--mid);margin-top:2px}
.raison-pct{font-size:10px;color:var(--sage);font-weight:600;margin-top:4px}

/* UTILS */
.pill{font-size:10px;font-weight:500;padding:3px 9px;border-radius:20px;display:inline-block}
.pill-sage{background:var(--sage-pale);color:var(--sage)}
.pill-coral{background:var(--coral-pale);color:var(--coral)}
.pill-gold{background:var(--gold-pale);color:var(--gold)}
.pill-plum{background:var(--plum-pale);color:var(--plum)}
.mt8{margin-top:8px}.mt12{margin-top:12px}.mt16{margin-top:16px}.mt20{margin-top:20px}.mt24{margin-top:24px}.mt32{margin-top:32px}
.mb8{margin-bottom:8px}.mb12{margin-bottom:12px}.mb16{margin-bottom:16px}.mb20{margin-bottom:20px}.mb24{margin-bottom:24px}.mb32{margin-bottom:32px}
.flex{display:flex}.fac{align-items:center}.fsp{justify-content:space-between}.gap8{gap:8px}.gap12{gap:12px}.gap16{gap:16px}
.text-mid{color:var(--mid)}.text-sage{color:var(--sage)}.text-coral{color:var(--coral)}.text-light{color:var(--light)}.text-gold{color:var(--gold)}
.fw500{font-weight:500}.fw600{font-weight:600}
.fs10{font-size:10px}.fs11{font-size:11px}.fs12{font-size:12px}.fs13{font-size:13px}.fs14{font-size:14px}
.serif{font-family:'Playfair Display',serif}
.divider{height:1px;background:var(--border);margin:18px 0}
.note-box{background:var(--gold-pale);border:1px solid rgba(184,144,58,0.22);border-radius:var(--r);padding:12px 16px;font-size:12px;color:var(--charcoal);line-height:1.6}
.note-box strong{color:var(--gold)}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-thumb{background:var(--cream3);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--light)}

/* HERO STAT (Vue d'ensemble) */
.hero-stat{background:linear-gradient(135deg,var(--charcoal) 0%,#3a4742 100%);color:white;border-radius:var(--r2);padding:28px 32px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:20px}
.hero-stat-content{flex:1;min-width:280px}
.hero-stat-eyebrow{font-size:10px;letter-spacing:.08em;text-transform:uppercase;opacity:.5;margin-bottom:8px}
.hero-stat-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:500;line-height:1.3;margin-bottom:8px}
.hero-stat-title .accent{color:#F2C4A8;font-style:italic}
.hero-stat-sub{font-size:13px;opacity:.7;line-height:1.6}
.hero-stat-numbers{display:flex;gap:32px;flex-wrap:wrap}
.hero-stat-num{text-align:right}
.hero-stat-num-val{font-family:'Playfair Display',serif;font-size:32px;font-weight:500;line-height:1;color:#F2C4A8}
.hero-stat-num-lbl{font-size:10px;letter-spacing:.05em;text-transform:uppercase;opacity:.6;margin-top:4px}

/* RESEARCH 3 NIVEAUX */
.research-tab-row{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:24px;flex-wrap:wrap}
.research-tab{padding:14px 22px;background:transparent;border:none;color:var(--mid);font-size:13px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;display:flex;align-items:center;gap:8px}
.research-tab:hover{color:var(--charcoal)}
.research-tab.on{color:var(--sage);border-bottom-color:var(--sage);font-weight:600}
.research-tab .tab-icon{width:14px;height:14px}

/* CARDS WITH ACCENT */
.accent-card{background:white;border:1px solid var(--border);border-radius:var(--r2);padding:22px;box-shadow:var(--sh);border-left:4px solid var(--sage);position:relative}
.accent-card.coral{border-left-color:var(--coral)}
.accent-card.gold{border-left-color:var(--gold)}
.accent-card.plum{border-left-color:var(--plum)}


/* ========== ERGOS RESEARCH (V3) ========== */
.ergo-section{background:white;border:1px solid var(--border);border-radius:var(--r2);padding:24px;box-shadow:var(--sh);margin-bottom:20px}
.ergo-section-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:500;line-height:1.2;margin-bottom:14px;display:flex;align-items:center;gap:12px}
.ergo-section-title .accent-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.ergo-section-sub{font-size:12px;color:var(--mid);margin-bottom:18px;line-height:1.55}

/* Stats KPI cards inside sections */
.kpi-mini{background:var(--cream);border:1px solid var(--border);border-radius:10px;padding:13px 14px;position:relative;overflow:hidden}
.kpi-mini-accent{position:absolute;top:0;left:0;width:3px;height:100%}
.kpi-mini-label{font-size:9px;font-weight:500;color:var(--mid);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}
.kpi-mini-value{font-family:'Playfair Display',serif;font-size:14px;font-weight:500;line-height:1.2;color:var(--charcoal);margin-bottom:4px}
.kpi-mini-detail{font-size:10px;color:var(--mid);line-height:1.45}

/* Cat-cards (chips groups) */
.cat-card{background:linear-gradient(135deg,var(--sage-pale),var(--cream));border:1px solid var(--border2);border-radius:10px;padding:14px}
.cat-card.coral{background:linear-gradient(135deg,var(--coral-pale),var(--cream));border-color:rgba(212,113,74,0.18)}
.cat-card.gold{background:linear-gradient(135deg,var(--gold-pale),var(--cream));border-color:rgba(184,144,58,0.22)}
.cat-card.plum{background:linear-gradient(135deg,var(--plum-pale),var(--cream));border-color:rgba(122,92,138,0.22)}
.cat-card-title{font-size:10px;font-weight:600;color:var(--charcoal);text-transform:uppercase;letter-spacing:.05em;margin-bottom:9px}
.cat-card-chips{display:flex;flex-wrap:wrap;gap:5px}
.cat-card-chip{font-size:10px;padding:3px 9px;border-radius:20px;background:white;color:var(--charcoal);border:1px solid var(--border)}

/* Dimensions cards */
.dim-card{background:var(--cream);border:1px solid var(--border);border-left:3px solid var(--plum);border-radius:10px;padding:14px}
.dim-card-num{font-family:'Playfair Display',serif;font-size:22px;font-weight:500;color:var(--plum);line-height:1}
.dim-card-name{font-size:12px;font-weight:600;color:var(--charcoal);margin-top:4px;line-height:1.3}
.dim-card-desc{font-size:10px;color:var(--mid);margin-top:6px;line-height:1.55}

/* DEV details (collapsibles) */
.dev-details{margin-top:18px;border-top:1px solid var(--border);padding-top:14px}
.dev-details summary{cursor:pointer;font-size:11px;font-weight:500;color:var(--sage);text-transform:uppercase;letter-spacing:.05em;padding:8px 12px;background:var(--cream);border-radius:8px;display:inline-flex;align-items:center;gap:8px;list-style:none;user-select:none}
.dev-details summary::-webkit-details-marker{display:none}
.dev-details summary::before{content:"▸";display:inline-block;transition:transform .2s;font-size:9px}
.dev-details[open] summary::before{transform:rotate(90deg)}
.dev-details summary:hover{background:var(--sage-pale)}
.dev-content{margin-top:18px;padding-left:6px}
.dev-content p{font-size:13px;line-height:1.75;color:var(--charcoal);margin-bottom:14px}
.dev-item{margin-bottom:18px;padding-left:14px;border-left:2px solid var(--border2)}
.dev-item-eyebrow{font-size:9px;font-weight:600;color:var(--coral);text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px}
.dev-item-title{font-family:'Playfair Display',serif;font-size:14px;font-weight:500;color:var(--charcoal);margin-bottom:6px;line-height:1.3}
.dev-item-desc{font-size:12px;color:var(--mid);line-height:1.7;margin-bottom:8px}
.dev-item-exs{padding-left:14px;list-style:none}
.dev-item-exs li{font-size:11px;color:var(--mid);line-height:1.55;margin-bottom:4px;position:relative;padding-left:10px}
.dev-item-exs li::before{content:"·";position:absolute;left:0;color:var(--sage);font-weight:600}
.dev-item-impl{margin-top:8px;padding:10px 12px;background:var(--cream);border-radius:8px;border-left:2px solid var(--gold)}
.dev-item-impl-title{font-size:9px;font-weight:600;color:var(--gold);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}
.dev-item-impl-text{font-size:11px;color:var(--charcoal);line-height:1.6}

/* Verbatim filters */
.verbatim-filters{background:var(--cream);border:1px solid var(--border);border-radius:var(--r2);padding:18px 20px;margin-bottom:18px}
.vf-row{display:flex;flex-wrap:wrap;align-items:flex-start;gap:14px;margin-bottom:12px}
.vf-row:last-child{margin-bottom:0}
.vf-label{font-size:10px;font-weight:600;color:var(--charcoal);text-transform:uppercase;letter-spacing:.06em;min-width:100px;padding-top:6px}
.vf-pills{display:flex;flex-wrap:wrap;gap:5px;flex:1}
.vf-pill{font-size:11px;padding:5px 11px;border-radius:18px;border:1px solid var(--border2);background:white;color:var(--mid);cursor:pointer;transition:all .12s;white-space:nowrap}
.vf-pill:hover{background:var(--cream2);color:var(--charcoal)}
.vf-pill.on{background:var(--sage);color:white;border-color:var(--sage);font-weight:500}
.vf-pill.coral.on{background:var(--coral);border-color:var(--coral)}
.vf-pill.gold.on{background:var(--gold);border-color:var(--gold)}
.vf-pill.plum.on{background:var(--plum);border-color:var(--plum)}
.vf-count{font-size:9px;opacity:.7;margin-left:3px;font-weight:400}

/* Verbatim card V3 */
.vbcard{background:white;border:1px solid var(--border);border-radius:var(--r2);padding:22px 22px 16px;box-shadow:var(--sh);position:relative;display:flex;flex-direction:column}
.vbcard::before{content:'\201C';font-family:'Playfair Display',serif;font-size:62px;color:var(--sage-pale);position:absolute;top:6px;left:14px;line-height:1}
.vbcard-text{font-size:13px;color:var(--charcoal);line-height:1.75;padding-top:18px;font-style:italic;flex:1}
.vbcard-meta{margin-top:14px;padding-top:12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.vbcard-code{font-size:10px;font-weight:600;color:var(--charcoal);background:var(--cream2);padding:2px 8px;border-radius:10px;letter-spacing:.04em}
.vbcard-ctx{font-size:10px;color:var(--mid);font-style:italic}
.vbcard-theme{font-size:10px;padding:2px 9px;border-radius:10px;font-weight:500}
.vbcard-theme.Leviers{background:var(--sage-pale);color:var(--sage)}
.vbcard-theme.Freins{background:var(--coral-pale);color:var(--coral)}
.vbcard-theme.\31 cans-de-valeur{background:var(--gold-pale);color:var(--gold)}
.vbcard-stheme{font-size:10px;color:var(--mid);background:var(--cream);padding:2px 8px;border-radius:10px}

/* Mini-film placeholder */
.minifilm-block{background:linear-gradient(135deg,var(--charcoal) 0%,#3a4742 100%);color:white;border-radius:var(--r2);padding:32px 28px;text-align:center;margin:24px 0;border:1px dashed rgba(242,196,168,0.4)}
.minifilm-icon{font-size:36px;color:#F2C4A8;margin-bottom:12px}
.minifilm-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:500;margin-bottom:8px}
.minifilm-title .accent{color:#F2C4A8;font-style:italic}
.minifilm-desc{font-size:12px;opacity:.7;line-height:1.6;max-width:540px;margin:0 auto}

/* Methodo box */
.methodo-box{background:var(--cream);border:1px solid var(--border);border-radius:var(--r2);padding:20px 22px;margin-bottom:24px}
.methodo-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.methodo-item{padding:10px 12px}
.methodo-item-num{font-family:'Playfair Display',serif;font-size:24px;font-weight:500;color:var(--sage);line-height:1}
.methodo-item-label{font-size:10px;color:var(--mid);text-transform:uppercase;letter-spacing:.04em;margin-top:5px;font-weight:500}
.methodo-item-detail{font-size:11px;color:var(--charcoal);margin-top:5px;line-height:1.5}
@media(max-width:780px){.methodo-grid{grid-template-columns:repeat(2,1fr)}}

/* Badge "données globales" pour graphiques non filtrables */
.badge-global{display:inline-flex;align-items:center;gap:5px;font-size:9px;font-weight:500;color:var(--mid);background:var(--cream2);padding:3px 9px;border-radius:12px;letter-spacing:.04em;text-transform:uppercase;margin-left:8px;border:1px solid var(--border)}
.badge-global::before{content:"●";color:var(--gold);font-size:8px}
</style>
</head>
<body>
<div class="app">


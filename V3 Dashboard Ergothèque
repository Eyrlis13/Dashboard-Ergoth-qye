function drawErgoMap() {
  const g = document.getElementById('ergo-map-markers');
  if (!g) return;
  const deptErgos = DATA.ergos_meta.filter(e => e.type === 'dept' && DATA.by_ergo[e.code]);
  const maxBenef = Math.max(...deptErgos.map(e => DATA.by_ergo[e.code].all.benef), 1);

  const svgNS = 'http://www.w3.org/2000/svg';
  g.innerHTML = '';
  ERGO_MAP_MARKERS.forEach(m => {
    const ergo = DATA.by_ergo[m.c];
    if (!ergo) return;
    const benef = ergo.all.benef;
    const r = 8 + 28 * Math.sqrt(benef / maxBenef);
    const c = document.createElementNS(svgNS, 'circle');
    c.setAttribute('cx', m.x);
    c.setAttribute('cy', m.y);
    c.setAttribute('r', r);
    c.setAttribute('fill', 'var(--sage)');
    c.setAttribute('fill-opacity', '0.65');
    c.setAttribute('stroke', 'white');
    c.setAttribute('stroke-width', '2');
    c.style.cursor = 'pointer';
    c.style.transition = 'fill-opacity .15s';
    c.addEventListener('mouseenter', (ev) => {
      c.setAttribute('fill-opacity', '0.95');
      showMapTip(ev, ergo.meta, benef);
    });
    c.addEventListener('mousemove', (ev) => showMapTip(ev, ergo.meta, benef));
    c.addEventListener('mouseleave', () => { c.setAttribute('fill-opacity', '0.65'); hideMapTip(); });
    c.addEventListener('click', () => showErgoDetail(m.c));
    g.appendChild(c);
    if (r >= 13) {
      const t = document.createElementNS(svgNS, 'text');
      t.setAttribute('x', m.x);
      t.setAttribute('y', m.y + 4);
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('font-size', Math.min(r, 14));
      t.setAttribute('font-weight', '500');
      t.setAttribute('fill', 'white');
      t.style.pointerEvents = 'none';
      t.style.fontFamily = "'DM Sans',sans-serif";
      t.textContent = m.c;
      g.appendChild(t);
    }
  });

  // Bailleurs panel
  const bail = DATA.ergos_meta.filter(e => e.type === 'bailleur');
  const bailMax = Math.max(...bail.map(e => DATA.by_ergo[e.code].all.benef), 1);
  document.getElementById('ergo-map-bailleurs').innerHTML = bail.map(e => {
    const a = DATA.by_ergo[e.code].all;
    const pct = 100 * a.benef / bailMax;
    return `<div onclick="showErgoDetail('${e.code}')" style="cursor:pointer;padding:10px 12px;margin-bottom:8px;background:var(--gold-pale);border:1px solid var(--border);border-radius:8px;transition:transform .12s" onmouseover="this.style.transform='translateX(2px)'" onmouseout="this.style.transform='none'">
      <div class="fw500 fs12" style="color:var(--gold)">${e.nom}</div>
      <div class="fs11 text-mid mt8">${fmt(a.benef)} bénéficiaires</div>
      <div style="margin-top:6px;height:4px;background:rgba(184,144,58,.18);border-radius:2px;overflow:hidden"><div style="width:${pct}%;height:100%;background:var(--gold)"></div></div>
    </div>`;
  }).join('');
}

function showMapTip(ev, meta, benef) {
  const tip = document.getElementById('ergo-map-tip');
  if (!tip) return;
  tip.innerHTML = `<div style="font-weight:500">${meta.titre}</div><div style="opacity:.85;margin-top:2px">${fmt(benef)} bénéficiaires · ${meta.region}</div>`;
  const wrap = tip.parentElement.getBoundingClientRect();
  tip.style.display = 'block';
  tip.style.left = (ev.clientX - wrap.left + 12) + 'px';
  tip.style.top = (ev.clientY - wrap.top + 12) + 'px';
}
function hideMapTip() {
  const tip = document.getElementById('ergo-map-tip');
  if (tip) tip.style.display = 'none';
}

function drawErgotheques() {
  // KPIs
  const totalDept = DATA.ergos_meta.filter(e => e.type === 'dept').length;
  const totalBail = DATA.ergos_meta.filter(e => e.type === 'bailleur').length;
  const totalBenef = DATA.global.benef;
  const totalRecyc = DATA.global.recyc;

  const kpis = [
    {label:'Ergothèques départementales', val:totalDept, sub:'Conseils départementaux'},
    {label:'Ergothèques bailleurs', val:totalBail, sub:'1001VH, CDC, HSA'},
    {label:'Total bénéficiaires', val:fmt(totalBenef), sub:'Toutes ergothèques'},
    {label:'Total AT recyclées', val:fmt(totalRecyc), sub:'Logique circulaire'}
  ];
  document.getElementById('ergo-kpis').innerHTML = kpis.map(k =>
    `<div class="kpi"><div class="kpi-label">${k.label}</div><div class="kpi-value">${k.val}</div><div class="kpi-sub">${k.sub}</div></div>`

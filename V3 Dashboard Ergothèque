function drawPersonnes() {
  const d = getCurrentData();

  // KPIs
  const totalGir = d.gir ? Object.values(d.gir).reduce((a,b)=>a+b,0) : 0;
  const isoOui = d.iso ? (d.iso['Oui']||0) : 0;
  const isoNon = d.iso ? (d.iso['Non']||0) : 0;
  const isoTot = isoOui + isoNon;
  const isoPct = isoTot > 0 ? (100*isoOui/isoTot) : 0;
  const fragiles = totalGir > 0 ? (100*((d.gir.g1||0)+(d.gir.g2||0)+(d.gir.g3||0))/totalGir) : 0;

  const pkpis = [
    {label:'Bénéficiaires', val:fmt(d.benef), sub:'Profil global'},
    {label:'Âge moyen', val:d.age_mean ? d.age_mean.toFixed(1).replace('.',',')+' ans' : '—', sub:'Population vieillissante'},
    {label:'Profils fragiles (GIR 1-3)', val:fmtPct(fragiles), sub:'Forte perte d\'autonomie'},
    {label:'Personnes isolées', val:fmtPct(isoPct), sub:fmt(isoOui)+' bénéficiaires'}
  ];
  document.getElementById('pers-kpis').innerHTML = pkpis.map(k =>
    `<div class="kpi"><div class="kpi-label">${k.label}</div><div class="kpi-value">${k.val}</div><div class="kpi-sub">${k.sub}</div></div>`
  ).join('');

  // GIR doughnut
  const girLabels = ['GIR 1','GIR 2','GIR 3','GIR 4','GIR 5','GIR 6'];
  const girVals = [d.gir.g1||0, d.gir.g2||0, d.gir.g3||0, d.gir.g4||0, d.gir.g5||0, d.gir.g6||0];
  const girColors = ['#7A2D1A','#C04E2A','#D4714A','#B8903A','#7FB5A5','#5A9E8C'];
  if (charts.gir) charts.gir.destroy();
  charts.gir = new Chart(document.getElementById('c-gir'), {
    type:'doughnut',
    data:{labels:girLabels, datasets:[{data:girVals, backgroundColor:girColors, borderWidth:0}]},
    options:{
      maintainAspectRatio:false, cutout:'58%',
      plugins:{legend:{position:'right', labels:{boxWidth:10, font:{size:10}, padding:5}},
               tooltip:{callbacks:{label:(c)=>c.label+': '+fmt(c.parsed)+' ('+(totalGir>0?(100*c.parsed/totalGir).toFixed(1).replace('.',','):0)+'%)'}}}
    }
  });

  // Âge doughnut
  const ageLabels = ['60-69','70-79','80-89','90+'];
  const ageVals = ageLabels.map(l => (d.age && d.age[l]) || 0);
  const ageColors = ['#E8DFD0','#D4C4A8','#B8903A','#8B6E2A'];
  const ageTot = ageVals.reduce((a,b)=>a+b,0);
  if (charts.age) charts.age.destroy();
  charts.age = new Chart(document.getElementById('c-age'), {
    type:'doughnut',
    data:{labels:ageLabels, datasets:[{data:ageVals, backgroundColor:ageColors, borderWidth:0}]},
    options:{
      maintainAspectRatio:false, cutout:'58%',
      plugins:{legend:{position:'right', labels:{boxWidth:10, font:{size:10}, padding:5}},
               tooltip:{callbacks:{label:(c)=>c.label+': '+fmt(c.parsed)+' ('+(ageTot>0?(100*c.parsed/ageTot).toFixed(1).replace('.',','):0)+'%)'}}}
    }
  });


    return DATA.by_ergo[b.code].all.benef - DATA.by_ergo[a.code].all.benef;
  });
  const maxBenef = Math.max(...sortedErgos.map(e => DATA.by_ergo[e.code].all.benef));
  tbody.innerHTML = sortedErgos.map(e => {
    const a = DATA.by_ergo[e.code].all;

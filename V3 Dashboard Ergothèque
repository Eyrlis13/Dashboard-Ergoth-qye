function drawEquipement() {
  const d = getCurrentData();

  document.getElementById('eq-pret').textContent = fmt(d.pret);
  document.getElementById('eq-achat').textContent = fmt(d.achat);
  document.getElementById('eq-nmep').textContent = fmt(d.nmep);
  document.getElementById('eq-recyc').textContent = fmt(d.recyc);

  const ratioPreco = d.benef > 0 ? (d.total / d.benef) : 0;
  const ratioPret = d.benef > 0 ? (d.pret / d.benef) : 0;
  document.getElementById('eq-ratio-preco').textContent = ratioPreco.toFixed(1).replace('.', ',');
  document.getElementById('eq-ratio-pret').textContent = ratioPret.toFixed(1).replace('.', ',');

  // Message modèle
  const tauxPret = d.total > 0 ? (100*d.pret/d.total) : 0;
  const tauxRecyc = d.pret > 0 ? (100*d.recyc/d.pret) : 0;
  const m = document.getElementById('model-message');
  m.innerHTML = `Sur les <strong>${fmt(d.total)} aides techniques préconisées</strong> par les ergothérapeutes du dispositif, <strong>${fmt(d.pret)} (${tauxPret.toFixed(0)}%)</strong> ont été mises à disposition gratuitement par Merci Julie — sans aucun reste à charge pour les bénéficiaires. <strong>${fmt(d.achat)} (${d.total>0?(100*d.achat/d.total).toFixed(0):0}%)</strong> ont été acquises directement par les bénéficiaires (parfois sur conseil de l'ergothérapeute, parfois pour des AT individualisées hors périmètre du prêt). Restent <strong>${fmt(d.nmep)} préconisations non acquises (${d.total>0?(100*d.nmep/d.total).toFixed(0):0}%)</strong> — soit hors périmètre prêt MJ, soit en attente, soit refusées. Sur les ${fmt(d.pret)} AT mises à disposition, <strong>${fmt(d.recyc)} (${tauxRecyc.toFixed(1).replace('.',',')}%)</strong> ont été récupérées et redistribuées à un autre bénéficiaire — une logique circulaire qui s'enracine.`;

  drawEqCross();

  // Catégories AT prêt (granulaire, filtré)
  const _g_eq = _getGranularData();
  const catPret = (_g_eq && _g_eq.cat_pret) ? _g_eq.cat_pret : {};
  const catEntries = Object.entries(catPret).sort((a,b)=>b[1]-a[1]);
  const catTotal = catEntries.reduce((s,[,v])=>s+v,0);
  document.getElementById('cat-pret-bars').innerHTML = catEntries.map(([cat,n]) => {
    const pct = (100*n/catTotal);
    return `<div class="stat-row">
      <div class="stat-label">${cat}</div>
      <div class="stat-bar-wrap"><div class="stat-bar-fill" style="width:${pct}%"></div></div>
      <div class="stat-pct">${pct.toFixed(0)}%</div>
    </div>`;
  }).join('');

  // Top 10 prêtées (granulaire)
  const _topPretObj = (_g_eq && _g_eq.top_pret) ? _g_eq.top_pret : {};
  const topPret = Object.entries(_topPretObj).sort((a,b)=>b[1]-a[1]).slice(0,10);
  const maxPret = topPret.length > 0 ? topPret[0][1] : 1;
  document.getElementById('top-pret-bars').innerHTML = topPret.length === 0 ? '<div class="text-mid fs12" style="padding:20px;text-align:center">Aucune donnée</div>' : topPret.map(([at,n]) => {
    const pct = 100*n/maxPret;
    const atShort = at.length > 50 ? at.slice(0,49)+'…' : at;
    return `<div class="stat-row">
      <div class="stat-label" style="font-size:11px">${atShort}</div>
      <div class="stat-bar-wrap"><div class="stat-bar-fill" style="width:${pct}%;background:${COL.sageM}"></div></div>
      <div class="stat-pct">${fmt(n)}</div>
    </div>`;
  }).join('');

  // Logique circulaire
  document.getElementById('circ-1').textContent = fmt(d.pret);
  // Tous les statuts "Récupérée" du global
  const recyclePotentiel = Math.round(d.pret * 0.18); // approximation : 18% des AT font le tour
  document.getElementById('circ-2').textContent = fmt(Math.round(d.recyc * 1.6)); // approx récupérées
  document.getElementById('circ-3').textContent = fmt(Math.round(d.recyc * 1.2)); // approx aseptisées
  document.getElementById('circ-4').textContent = fmt(d.recyc);
  document.getElementById('recyc-rate-pill').textContent = 'Taux recyclage : ' + tauxRecyc.toFixed(1).replace('.',',') + '%';

  // Top recyclées (granulaire)
  const _topRecycObj = (_g_eq && _g_eq.top_recyc) ? _g_eq.top_recyc : {};
  const topRecyc = Object.entries(_topRecycObj).sort((a,b)=>b[1]-a[1]).slice(0,10);
  if (topRecyc.length > 0) {
    const maxRec = topRecyc[0][1];
    document.getElementById('top-recyc-bars').innerHTML = topRecyc.map(([at,n]) => {
      const pct = 100*n/maxRec;
      const atShort = at.length > 45 ? at.slice(0,44)+'…' : at;
      return `<div class="stat-row">
        <div class="stat-label" style="font-size:11px">${atShort}</div>
        <div class="stat-bar-wrap"><div class="stat-bar-fill" style="width:${pct}%;background:${COL.coral}"></div></div>
        <div class="stat-pct">${fmt(n)}</div>
      </div>`;
